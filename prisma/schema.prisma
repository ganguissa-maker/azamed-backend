generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String                @id @default(uuid())
  email        String                @unique
  passwordHash String                @map("password_hash")
  role         RoleUtilisateur       @default(PATIENT)
  isVerified   Boolean               @default(false) @map("is_verified")
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  recherches   HistoriqueRecherche[]
  structure    Structure?

  @@map("users")
}

model Structure {
  id                   String                @id @default(uuid())
  userId               String                @unique @map("user_id")
  nomLegal             String                @map("nom_legal")
  nomCommercial        String                @map("nom_commercial")
  typeStructure        TypeStructure         @map("type_structure")
  telephone            String
  whatsapp             String?
  email                String?
  adresse              String
  pays                 String                @default("Côte d'Ivoire")
  ville                String
  quartier             String?
  latitude             Float?
  longitude            Float?
  horaires             Json?
  joursFeries          Json?                 @map("jours_feries")
  logoUrl              String?               @map("logo_url")
  photoUrl             String?               @map("photo_url")
  description          String?
  statutJuridique      StatutJuridique?      @map("statut_juridique")
  isVerified           Boolean               @default(false) @map("is_verified")
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  estDeGarde           Boolean               @default(false) @map("est_de_garde")
  heureFermeture       String?               @map("heure_fermeture")
  heureOuverture       String?               @map("heure_ouverture")
  medecinDeGarde       Boolean               @default(false) @map("medecin_de_garde")
  modules_json         String?               @default("{}")
  abonnements          Abonnement[]
  analyticsEvents      AnalyticsEvent[]
  hopitalServices      HopitalService[]
  laboExamens          LaboExamen[]
  pharmacieMedicaments PharmacieMedicament[]
  posts                Post[]
  user                 User                  @relation(fields: [userId], references: [id])

  @@map("structures")
}

model Abonnement {
  id              String           @id @default(uuid())
  structureId     String           @map("structure_id")
  niveau          NiveauAbonnement @default(BASIC)
  dateDebut       DateTime         @map("date_debut")
  dateFin         DateTime?        @map("date_fin")
  montant         Float            @default(0)
  devise          String           @default("XOF")
  statutPaiement  StatutPaiement   @default(EN_ATTENTE) @map("statut_paiement")
  transactionId   String?          @map("transaction_id")
  methodePaiement String?          @map("methode_paiement")
  createdAt       DateTime         @default(now()) @map("created_at")
  structure       Structure        @relation(fields: [structureId], references: [id])

  @@map("abonnements")
}

model Medicament {
  id                   String                @id @default(uuid())
  nomCommercial        String                @map("nom_commercial")
  dci                  String
  classeTherapeutique  String                @map("classe_therapeutique")
  forme                String
  dosage               String
  laboratoireFabricant String                @map("laboratoire_fabricant")
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at")
  pharmacieMedicaments PharmacieMedicament[]

  @@map("medicaments")
}

model PharmacieMedicament {
  id           String     @id @default(uuid())
  pharmacieId  String     @map("pharmacie_id")
  medicamentId String     @map("medicament_id")
  disponible   Boolean    @default(false)
  enStock      Boolean    @default(false) @map("en_stock")
  prix         Float?
  deGarde      Boolean    @default(false) @map("de_garde")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  medicament   Medicament @relation(fields: [medicamentId], references: [id])
  pharmacie    Structure  @relation(fields: [pharmacieId], references: [id])

  @@unique([pharmacieId, medicamentId])
  @@map("pharmacie_medicaments")
}

model Examen {
  id          String       @id @default(uuid())
  nom         String
  codeAzamed  String       @unique @map("code_azamed")
  categorie   String
  description String?
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  laboExamens LaboExamen[]

  @@map("examens")
}

model LaboExamen {
  id         String    @id @default(uuid())
  laboId     String    @map("labo_id")
  examenId   String    @map("examen_id")
  disponible Boolean   @default(false)
  prix       Float?
  delaiMin   Int?      @map("delai_min")
  delaiMax   Int?      @map("delai_max")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  examen     Examen    @relation(fields: [examenId], references: [id])
  labo       Structure @relation(fields: [laboId], references: [id])

  @@unique([laboId, examenId])
  @@map("labo_examens")
}

model ServiceMedical {
  id              String           @id @default(uuid())
  nom             String
  categorie       String
  description     String?
  isActive        Boolean          @default(true) @map("is_active")
  hopitalServices HopitalService[]

  @@map("services_medicaux")
}

model HopitalService {
  id                 String         @id @default(uuid())
  hopitalId          String         @map("hopital_id")
  serviceId          String         @map("service_id")
  disponible         Boolean        @default(false)
  surRdv             Boolean        @default(false) @map("sur_rdv")
  horaires           Json?
  prixConsultation   Float?         @map("prix_consultation")
  prixChambre        Float?         @map("prix_chambre")
  infoSupplementaire String?        @map("info_supplementaire")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  modeConsultation   String?        @default("JOURS_OUVRABLES") @map("mode_consultation")
  hopital            Structure      @relation(fields: [hopitalId], references: [id])
  service            ServiceMedical @relation(fields: [serviceId], references: [id])

  @@unique([hopitalId, serviceId])
  @@map("hopital_services")
}

model Post {
  id          String    @id @default(uuid())
  structureId String    @map("structure_id")
  contenu     String
  typePost    TypePost  @default(AUTRE) @map("type_post")
  mediaUrl    String?   @map("media_url")
  videoUrl    String?   @map("video_url")
  isPinned    Boolean   @default(false) @map("is_pinned")
  isApproved  Boolean   @default(true) @map("is_approved")
  isActive    Boolean   @default(true) @map("is_active")
  vues        Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  expiresAt   DateTime? @map("expires_at")
  structure   Structure @relation(fields: [structureId], references: [id])

  @@map("posts")
}

model AnalyticsEvent {
  id          String     @id @default(uuid())
  structureId String?    @map("structure_id")
  eventType   String     @map("event_type")
  metadata    Json?
  userIp      String?    @map("user_ip")
  userAgent   String?    @map("user_agent")
  createdAt   DateTime   @default(now()) @map("created_at")
  structure   Structure? @relation(fields: [structureId], references: [id])

  @@map("analytics_events")
}

model HistoriqueRecherche {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  query     String
  type      String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("historique_recherches")
}

model ProfilUtilisateur {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId       String   @unique
  prenom       String   @default("")
  nom          String   @default("")
  telephone    String?
  whatsapp     String?
  ville        String?
  pays         String?  @default("Cameroun")
  typeCompte   String   @default("UTILISATEUR")
  specialite   String?
  numeroOrdre  String?
  lieuExercice String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())
}

model consultations {
  id               String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  patientId        String
  medecinId        String?
  typeConsultation String   @default("GENERALISTE")
  specialite       String?
  description      String?
  lieu             String?
  adressePatient   String?
  statut           String   @default("EN_ATTENTE")
  dateProposee     String?
  heureProposee    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())
  quartierPatient  String?
  prix             Decimal? @db.Decimal
  nomCabinet       String?
  quartierCabinet  String?
}

model notifications {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  type      String
  titre     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model notifications_consult {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  type      String
  titre     String
  message   String
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model password_resets {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model profils_utilisateurs {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId       String   @unique
  prenom       String?
  nom          String?
  ville        String?
  telephone    String?
  specialite   String?
  numeroOrdre  String?
  lieuExercice String?
  createdAt    DateTime @default(now())
}

enum TypeStructure {
  PHARMACIE
  LABORATOIRE
  HOPITAL_PUBLIC
  HOPITAL_PRIVE
  CLINIQUE
  CABINET_MEDICAL
  CABINET_SPECIALISE
  CENTRE_SANTE
  AUTRE
  LABO_ET_IMAGERIE
  CENTRE_IMAGERIE
  POLYCLINIQUE
}

enum StatutJuridique {
  PRIVE
  PUBLIC
  CONFESSIONNEL
}

enum NiveauAbonnement {
  BASIC
  PREMIUM1
  PREMIUM2
}

enum StatutPaiement {
  EN_ATTENTE
  CONFIRME
  ECHOUE
  REMBOURSE
}

enum TypePost {
  NOUVEAU_SERVICE
  PROMOTION
  DISPONIBILITE_MEDICAMENT
  NOUVEL_EXAMEN
  CAMPAGNE_DEPISTAGE
  HORAIRES_MODIFIES
  EVENEMENT_MEDICAL
  RECRUTEMENT
  MESSAGE_INSTITUTIONNEL
  AUTRE
}

enum RoleUtilisateur {
  PATIENT
  STRUCTURE
  ADMIN
  MEDECIN
  DELEGUE
}
